{
  "name": "context7-docs",
  "displayName": "Context7 Docs (For Human)",
  "description": "Search library docs, code snippets, and examples directly in VS Code",
  "version": "0.1.1523",
  "publisher": "JohnnRen",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/john-walks-slow/context7-docs-vscode"
  },
  "bugs": {
    "url": "https://github.com/john-walks-slow/context7-docs-vscode/issues"
  },
  "homepage": "https://github.com/john-walks-slow/context7-docs-vscode#readme",
  "keywords": [
    "documentation",
    "search",
    "context7",
    "code snippets",
    "library docs",
    "api docs",
    "react",
    "vue",
    "angular",
    "svelte",
    "next.js",
    "python",
    "rust",
    "golang",
    "typescript",
    "javascript",
    "LSP"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "localizations": [
      {
        "languageId": "en",
        "languageName": "English",
        "translations": [
          {
            "id": "context7-docs",
            "path": "./locales/en.json"
          }
        ]
      },
      {
        "languageId": "zh-cn",
        "languageName": "简体中文",
        "translations": [
          {
            "id": "context7-docs",
            "path": "./locales/zh-cn.json"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "context7.search",
        "title": "Context7: Search Documentation",
        "icon": "$(search)"
      },
      {
        "command": "context7.manageLibraries",
        "title": "Context7: Manage Libraries",
        "icon": "$(settings-gear)"
      },
      {
        "command": "context7.searchSelection",
        "title": "Context7: Search Selection",
        "icon": "$(search)"
      },
      {
        "command": "context7.configureApiKey",
        "title": "Context7: Configure API Key"
      },
      {
        "command": "context7.viewHistory",
        "title": "Context7: View Search History",
        "icon": "$(history)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "context7.searchSelection",
          "when": "editorHasSelection",
          "group": "search@1"
        }
      ],
      "view/title": [
        {
          "command": "context7.search",
          "when": "view == context7.search",
          "group": "navigation@1"
        },
        {
          "command": "context7.viewHistory",
          "when": "view == context7.search",
          "group": "navigation@2"
        },
        {
          "command": "context7.manageLibraries",
          "when": "view == context7.search",
          "group": "navigation@3"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "context7",
          "title": "Context7 Docs",
          "icon": "resources/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "context7": [
        {
          "icon": "resources/icon-sidebar.svg",
          "type": "webview",
          "id": "context7.search",
          "name": "Documentation Search"
        }
      ]
    },
    "configuration": {
      "title": "Context7 Docs",
      "properties": {
        "context7.libraries": {
          "type": "array",
          "default": [
            {
              "id": "/websites/react_dev",
              "name": "react"
            },
            {
              "id": "/vuejs/vue",
              "name": "vue"
            },
            {
              "id": "/microsoft/TypeScript",
              "name": "typescript"
            },
            {
              "id": "/vercel/next.js",
              "name": "next.js"
            },
            {
              "id": "/tailwindlabs/tailwindcss",
              "name": "tailwindcss"
            },
            {
              "id": "/vitejs/vite",
              "name": "vite"
            },
            {
              "id": "/prisma/prisma",
              "name": "prisma"
            },
            {
              "id": "/colinhacks/zod",
              "name": "zod"
            }
          ],
          "description": "Library list for documentation search. Each item requires 'id' and 'name' properties.",
          "scope": "application"
        },
        "context7.pathPatterns": {
          "type": "array",
          "default": [
            {
              "languages": [
                "javascript",
                "typescript",
                "javascriptreact",
                "typescriptreact",
                "vue"
              ],
              "pattern": ".*node_modules/@types/([^/]+)"
            },
            {
              "languages": [
                "javascript",
                "typescript",
                "javascriptreact",
                "typescriptreact",
                "vue"
              ],
              "pattern": ".*node_modules/(@[^/]+/[^/]+|[^/]+)"
            },
            {
              "languages": [
                "python"
              ],
              "pattern": ".*site-packages/([^/]+)"
            },
            {
              "languages": [
                "go"
              ],
              "pattern": ".*pkg/mod/(.+)@"
            },
            {
              "languages": [
                "rust"
              ],
              "pattern": ".*registry/src/[^/]+/(.+)-\\d+\\.\\d+"
            },
            {
              "languages": [
                "java"
              ],
              "pattern": ".*\\.m2/repository/(.+/[^/]+)/\\d"
            },
            {
              "languages": [
                "java"
              ],
              "pattern": ".*\\.gradle/caches/modules-\\d+/files-\\d+\\.\\d+/([^/]+/[^/]+)"
            },
            {
              "languages": [
                "csharp"
              ],
              "pattern": ".*[/\\\\](?:\\.nuget/packages|packages)[/\\\\]([^/\\\\]+)"
            },
            {
              "languages": [
                "ruby"
              ],
              "pattern": ".*gems/(.+)-\\d+\\.\\d+"
            },
            {
              "languages": [
                "php"
              ],
              "pattern": ".*vendor/([^/]+/[^/]+)"
            },
            {
              "languages": [
                "dart"
              ],
              "pattern": ".*(?:\\.pub-cache|Pub/Cache)/hosted/[^/]+/(.+)-\\d+\\.\\d+"
            }
          ],
          "description": "Path patterns to extract library names from definition file paths. Each item has 'languages' (array) and 'pattern' (regex string). User patterns are prepended to defaults.",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm build",
    "build": "vite build",
    "watch": "vite build --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pack:vsix": "vsce package --no-dependencies",
    "publish:vsix": "vsce publish --no-dependencies -o build/<name>-<version>.vsix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.101.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.20.0",
    "globals": "^17.4.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "marked": "^17.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.0.2"
  }
}
