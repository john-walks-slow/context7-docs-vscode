{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": ["--extensionDevelopmentPath=${workspaceFolder}"],
			"outFiles": ["${workspaceFolder}/dist/**/*.js"],
			"preLaunchTask": "${defaultBuildTask}"
		},
		{
			"name": "Run Extension (Temp Profile)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--profile-temp",
				"${workspaceFolder}",
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": ["${workspaceFolder}/dist/**/*.js"],
			"preLaunchTask": "${defaultBuildTask}"
		}
	]
}
